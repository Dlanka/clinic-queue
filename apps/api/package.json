  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "seed": "tsx src/scripts/seed.ts"
